            "key": "\u001b[90mв”Ӯ\u001b[36m пҮ‘ OS   :",
            "format": "{3}\u001b[1m\u001b[90m                 в”Ӯ"
        },
        {
            "type": "host",
            "key": "\u001b[90mв”Ӯ\u001b[36m у°Ңў Host :",
            "format": "{1}\u001b[1m\u001b[90m              в”Ӯ"
        },
        {
            "type": "cpu",
            "key": "\u001b[90mв”Ӯ\u001b[36m п’ј CPU  :",
            "format": "{1}\u001b[1m\u001b[90m в”Ӯ"
        },
