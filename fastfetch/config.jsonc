            "type": "gpu",
            "key": "\u001b[90mв”Ӯ\u001b[36m у°№‘ GPU  :",
            "format": "{1} {2}\u001b[1m\u001b[90m     в”Ӯ"
        },
        {
            "type": "memory",
            "key": "\u001b[90mв”Ӯ\u001b[36m у°‘ӯ RAM  :",
            "format": "{1} / {2}\u001b[1m\u001b[90m       в”Ӯ"
        },
        {
            "type": "custom",
            "format": "\u001b[1m\u001b[90mв•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ"
